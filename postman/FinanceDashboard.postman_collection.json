{
  "info": {
    "name": "Finance Dashboard Backend",
    "_postman_id": "5d0619cb-9267-4be1-96a8-4de808c8d247",
    "description": "Account-free Postman collection for local testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "adminEmail", "value": "admin@finance.com" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "adminToken", "value": "" },
    { "key": "recordId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth / Login (Admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json?.data?.token) {",
              "  pm.collectionVariables.set('adminToken', json.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Auth / Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },
    {
      "name": "Records / List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/records?limit=5"
      }
    },
    {
      "name": "Records / Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json?.data?.record?.id) {",
              "  pm.collectionVariables.set('recordId', json.data.record.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 2500,\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"date\": \"2026-04-01\",\n  \"description\": \"Created from Postman\"\n}"
        },
        "url": "{{baseUrl}}/api/records"
      }
    },
    {
      "name": "Records / Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 3000,\n  \"description\": \"Updated from Postman\"\n}"
        },
        "url": "{{baseUrl}}/api/records/{{recordId}}"
      }
    },
    {
      "name": "Dashboard / Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/dashboard/summary"
      }
    },
    {
      "name": "Dashboard / Recent",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/dashboard/recent?limit=5"
      }
    },
    {
      "name": "Dashboard / By Category",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/dashboard/by-category"
      }
    },
    {
      "name": "Dashboard / Trends",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/dashboard/trends?period=monthly&months=6"
      }
    },
    {
      "name": "Users / List (Admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const users = json?.data?.users || [];",
              "const analyst = users.find(u => u.role === 'analyst');",
              "if (analyst?.id) {",
              "  pm.collectionVariables.set('userId', analyst.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Users / Update Role",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"viewer\"\n}"
        },
        "url": "{{baseUrl}}/api/users/{{userId}}/role"
      }
    },
    {
      "name": "Records / Delete",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/records/{{recordId}}"
      }
    }
  ]
}
